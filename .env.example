# متجر أبو سرور كارد - ملف المتغيرات البيئية
# Abu Surur Store - Environment Variables

# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=abu_surur_store
DB_USER=admin
DB_PASSWORD=your_password

# API Keys
SYRITEL_API_KEY=your_syritel_api_key
MTN_API_KEY=your_mtn_api_key
SHAMCASH_API_KEY=your_shamcash_api_key

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRE=7d

# Application Settings
APP_NAME=Abu Surur Store
APP_VERSION=1.0.0
